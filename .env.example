# Banco de dados (Prisma)
DATABASE_URL="mysql://usuario:senha@localhost:3306/outorga"

# NextAuth v5
AUTH_SECRET=
AUTH_URL="http://localhost:3001"

# local = login sem LDAP; outro valor = autenticação via LDAP
ENVIRONMENT=local

# LDAP (obrigatório quando ENVIRONMENT != local)
LDAP_SERVER=
LDAP_DOMAIN=
LDAP_BASE=
USER_LDAP=
PASS_LDAP=

# Descomente em deploy atrás de proxy, se necessário
# AUTH_TRUST_HOST=true
